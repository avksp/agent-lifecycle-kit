    "modelProfileTrustRootEnvironment": "AGENT_LIFECYCLE_LIVE_COST_TRUST_ROOT",
    "expectedSignerFingerprintEnvironment": "AGENT_LIFECYCLE_LIVE_COST_SIGNER_FINGERPRINT",
    "maximumProfileAgeHours": 24,
    "requiredProfileFields": [
