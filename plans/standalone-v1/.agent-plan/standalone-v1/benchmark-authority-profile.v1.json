    ],
    "laterReleaseSequence": [
      "verify-prior-baseline-signature-and-lineage",
      "run-deterministic-benchmark",
      "compare-absolute-and-relative-gates",
      "independent-audit-candidate-measurements",
      "bind-audit-approved-candidate-and-predecessor-digests",
      "sign-sha256-of-canonical-payload",
      "verify-signature-and-fingerprint",
      "publish-baseline"
