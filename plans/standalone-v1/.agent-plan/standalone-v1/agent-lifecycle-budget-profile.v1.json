    "logicalSemanticCallsPerRun": "sum of every task-scoped and lifecycle-scoped logical semantic call in one run",
    "cumulativeContextBytesPerRun": "sum of exact contextBytesPerCall values for every logical semantic call in one run",
    "liveModelInvocation": "one actual provider call; always zero in deterministic replay and nonzero only in live calibration",
