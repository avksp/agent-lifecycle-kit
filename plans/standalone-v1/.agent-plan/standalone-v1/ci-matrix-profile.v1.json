    },
    {
      "id": "macos-py311",
      "osFamily": "macOS 14",
      "architecture": "arm64",
      "pythonMinor": "3.11"
    },
    {
      "id": "macos-py312",
      "osFamily": "macOS 14",
      "architecture": "arm64",
      "pythonMinor": "3.12"
    },
    {
      "id": "macos-py313",
