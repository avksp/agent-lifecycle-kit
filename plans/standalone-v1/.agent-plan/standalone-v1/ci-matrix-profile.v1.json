    "legId",
    "runnerImageDigest",
    "architecture",
    "pythonPatchRange",
    "toolchainRanges",
    "commandSetSha256",
    "ciSigningAuthorityFingerprint",
    "receiptLifetimeSeconds",
    "networkScope",
    "secretScope"
