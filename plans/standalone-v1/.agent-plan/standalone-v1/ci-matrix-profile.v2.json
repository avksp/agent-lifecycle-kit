{
  "schemaVersion": "agent-lifecycle-ci-matrix-profile.v2",
  "profileId": "agent-lifecycle-ci-matrix-authority.v2",
  "commandSetId": "agent-lifecycle-release-matrix.v2",
  "authority": {
    "algorithm": "Ed25519",
    "allowlistPathEnvironment": "AGENT_LIFECYCLE_CI_MATRIX_ALLOWLIST_FILE",
    "trustRootPathEnvironment": "AGENT_LIFECYCLE_CI_MATRIX_TRUST_ROOT",
    "maximumAgeHours": 24,
    "controllerStoredFields": [
      "allowlistSha256",
      "authorityFingerprint",
      "expiresAt",
      "legProfileIds",
      "commandSetSha256"
    ],
    "receiptMaySelectProfile": false
  },
  "legProfiles": [
    {"id":"linux-py311","osFamily":"Ubuntu 24.04","architecture":"x86_64","pythonMinor":"3.11"},
    {"id":"linux-py312","osFamily":"Ubuntu 24.04","architecture":"x86_64","pythonMinor":"3.12"},
    {"id":"linux-py313","osFamily":"Ubuntu 24.04","architecture":"x86_64","pythonMinor":"3.13"},
    {"id":"macos-py311","osFamily":"macOS 14","architecture":"arm64","pythonMinor":"3.11"},
    {"id":"macos-py312","osFamily":"macOS 14","architecture":"arm64","pythonMinor":"3.12"},
    {"id":"macos-py313","osFamily":"macOS 14","architecture":"arm64","pythonMinor":"3.13"},
    {"id":"windows-py311","osFamily":"Windows Server 2022","architecture":"x86_64","pythonMinor":"3.11"},
    {"id":"windows-py312","osFamily":"Windows Server 2022","architecture":"x86_64","pythonMinor":"3.12"},
    {"id":"windows-py313","osFamily":"Windows Server 2022","architecture":"x86_64","pythonMinor":"3.13"}
  ],
  "requiredAllowlistLegFields": [
    "legId",
    "runnerImageDigest",
    "architecture",
    "pythonPatchRange",
    "toolchainRanges",
    "commandSetSha256",
    "ciSigningAuthorityFingerprint",
    "receiptLifetimeSeconds",
    "networkScope",
    "secretScope"
  ],
  "requiredLegReceiptFields": [
    "legId",
    "sourceRevision",
    "dependencyLockDigest",
    "runnerImageDigest",
    "architecture",
    "interpreterIdentity",
    "toolchainIdentity",
    "commandSetSha256",
    "candidatePayloadInventoryDigest",
    "candidatePayloadObjectManifestDigest",
    "startedAt",
    "finishedAt",
    "authorityFingerprint",
    "signature"
  ],
  "candidatePayloadIdentity": {
    "field": "candidatePayloadInventoryDigest",
    "definitionProfile": "plans/standalone-v1/.agent-plan/standalone-v1/release-assembly-profile.v1.json",
    "nonRecursivePayloadBytesOnly": true,
    "everyLegMustBind": true,
    "allLegValuesMustEqual": true,
    "mustNotClaimFutureFinalInventoryDigest": true
  },
  "dispatch": {
    "producer": "external-ci-authority",
    "workerSelfSignedReceiptAllowed": false,
    "localPreflightPromotesRelease": false,
    "allLegsSameSourceRevision": true,
    "allLegsSameDependencyLock": true,
    "allLegsSameCommandSet": true,
    "allLegsSameCandidatePayloadInventoryDigest": true,
    "aggregateRequiresExactLegSet": true
  },
  "aggregate": {
    "schemaVersion": "agent-lifecycle-ci-matrix-aggregate.v2",
    "exactLegCount": 9,
    "rejectMissingStaleDuplicateIncompatibleOrSelfAssertedLegs": true,
    "requiredBindings": [
      "exactLegReceiptIdentitySet",
      "sourceRevision",
      "dependencyLockDigest",
      "commandSetSha256",
      "candidatePayloadInventoryDigest",
      "allowlistSha256",
      "authorityFingerprint"
    ],
    "finalInventoryDigestForbidden": true
  },
  "negativeConformance": {
    "requiredCases": [
      "missing-or-duplicate-leg",
      "wrong-os-architecture-or-python",
      "source-lock-command-or-toolchain-mismatch",
      "candidate-payload-digest-mismatch",
      "future-final-inventory-claim",
      "stale-or-untrusted-authority",
      "self-asserted-or-mutated-receipt"
    ]
  }
}
